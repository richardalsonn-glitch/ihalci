            <!-- tab product start -->
            

            <!-- rd slide product start -->
            <div class="rd-slide-product">
                <div class="container">
                    <div class="row mt-none-30">
                        <div class="col-lg-3 mt-30">
                            <div class="product-category" data-background="/home/img/img/bg/cat_bg.jpg">
                                <h2 class="section-heading mb-25"><span><span>Kategoriler</span></span></h2>
                                <ul class="list-unstyled">
                                    <% kategoriler.forEach(element => { %>
                                        
                                 
                                    <li class="cat-item-has-children"><a href="/kategoriler/<%- element.kategoriurl  %>"><img src="/home/img/img/icon/cat_01.svg" alt=""><%- element.kategoriadi  %></a></li>
                                <% }); %>
                                   
                                </ul>
                            </div>
                        </div>
                      

                        <script>
                            window.addEventListener('load', function() {
                                var productItems = document.querySelectorAll('.product__item');
                                var maxHeight = 0;
                    
                                productItems.forEach(function(item) {
                                    if (item.offsetHeight > maxHeight) {
                                        maxHeight = item.offsetHeight;
                                    }
                                });
                    
                                productItems.forEach(function(item) {
                                    item.style.height = maxHeight + 'px';
                                });
                            });
                        </script>
                        <div class="col-lg-9 mt-30">
                            <div class="rd-slide-products">
                                <h2 class="section-heading mb-25"><span>Son Eklenenler</span></h2>
                                <div class="rd-product__slide tx-arrow">
                                    <% for (let i = 0; i < urunler.length; i += 4) { %>
                                      
                                    <div class="rd-product__slide-item">
                                        <% for (let j = i; j < i + 4 && j < urunler.length; j++) { %>
                                        <div class="product__item">
                                            <div class="product__img text-center pos-rel">
                                                <a href="/urunler/<%- urunler[j].ihaleurl  %>"><img src="/urungorselleri/<%- urunler[j].urungorsel1  %>" alt="" height="120px" width="120px"></a>
                                            </div>
                                            <div class="product__content">
                                                <div class="product__review ul_li_center">
                                                 
                                                    <ul class="rating-star ul_li mr-10">
                                                        <li><i class="fas fa-star"></i></li>
                                                        <li><i class="fas fa-star"></i></li>
                                                        <li><i class="fas fa-star"></i></li>
                                                        <li><i class="far fa-star"></i></li>
                                                        <li><i class="far fa-star"></i></li>
                                                    </ul>
                                                    <span>(126) Değerlendirme</span>
                                                </div>
                                                <h2 class="product__title"><a href="/urunler/<%- urunler[j].ihaleurl  %>"><%- urunler[j].urunadi %></a></h2>
                                                <h4 class="product__price"><span class="Yeni"><%- urunler[j].baslangicfiyati %> TL</span><span class="old"><%- urunler[j].urunfiyati %> TL </span></h4>
                                            </div>
                                            <ul class="product__action">
                                                <li><a href="#!"><i class="far fa-compress-alt"></i></a></li>
                                                <li><a href="#!"><i class="far fa-shopping-basket"></i></a></li>
                                                <li><a href="#!"><i class="far fa-heart"></i></a></li>
                                            </ul>
                                            <span class="badge-skew">Yeni</span>
                                        </div>
                                        <% } %>
                                    </div>
                                    <% } %>
                                </div>
                            </div>
                        </div>







                    </div>
                </div>
            </div>
