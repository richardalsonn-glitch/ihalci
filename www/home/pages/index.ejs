        <main>
            <!-- hero start -->
<div class="hero hero__height ul_li" style="background: linear-gradient(135deg, #1f1f1f 0%, #2c2c2c 100%); padding: 50px 0;">
    <div class="container">
        <div class="row align-items-stretch mt-none-30">

            <!-- SOL BÜYÜK CANLI İHALE -->
            <div class="col-lg-8 mt-30">
                <% slider.slice(0, 1).forEach(element => { %>
                <div style="background:#fff;border-radius:18px;padding:30px;box-shadow:0 10px 30px rgba(0,0,0,0.12);height:100%;">
                    <div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:10px;margin-bottom:20px;">
                        <span style="background:#ff7a00;color:#fff;padding:10px 16px;border-radius:10px;font-weight:700;">
                            🔴 CANLI İHALE
                        </span>
                        <div style="font-size:16px;font-weight:600;color:#444;">
                            Kalan Süre: <span style="color:#ff7a00;font-size:20px;">00:09:42</span>
                        </div>
                    </div>

                    <div class="row align-items-center">
                        <div class="col-lg-7">
                            <div style="text-align:center;">
                                <img src="/slider/<%- element.slidegorsel %>" alt="" style="max-width:100%;max-height:340px;object-fit:contain;">
                            </div>
                        </div>

                        <div class="col-lg-5">
                            <div>
                                <div style="font-size:14px;color:#888;font-weight:600;margin-bottom:8px;">Sıcak İhale</div>
                                <h2 style="font-size:34px;font-weight:800;color:#222;margin-bottom:10px;"><%- element.slideadi %></h2>
                                <p style="font-size:16px;color:#666;margin-bottom:20px;"><%- element.slidealtadi %></p>

                                <div style="margin-bottom:18px;">
                                    <div style="font-size:14px;color:#888;">Anlık Teklif</div>
                                    <div style="font-size:40px;font-weight:800;color:#222;"><%- element.slideurunbaslangicfiyati %> TL</div>
                                </div>

                                <div style="display:grid;grid-template-columns:repeat(2,minmax(120px,1fr));gap:12px;margin-bottom:20px;">
                                    <div style="background:#f7f7f7;padding:14px;border-radius:12px;">
                                        <div style="font-size:13px;color:#888;">Sıradaki Teklif</div>
                                        <div style="font-size:20px;font-weight:700;color:#ff7a00;">250 Jeton</div>
                                    </div>
                                    <div style="background:#f7f7f7;padding:14px;border-radius:12px;">
                                        <div style="font-size:13px;color:#888;">Katılımcı</div>
                                        <div style="font-size:20px;font-weight:700;color:#222;">42 Kişi</div>
                                    </div>
                                    <div style="background:#f7f7f7;padding:14px;border-radius:12px;">
                                        <div style="font-size:13px;color:#888;">Toplam Teklif</div>
                                        <div style="font-size:20px;font-weight:700;color:#222;">186</div>
                                    </div>
                                    <div style="background:#f7f7f7;padding:14px;border-radius:12px;">
                                        <div style="font-size:13px;color:#888;">Son Teklif</div>
                                        <div style="font-size:20px;font-weight:700;color:#222;">Ali***</div>
                                    </div>
                                </div>

                                <div style="display:flex;gap:12px;flex-wrap:wrap;">
                                    <a class="hero__btn" href="<%- element.slideurunlinki %>" style="margin:0;">İhaleye Katıl <i class="far fa-long-arrow-right"></i></a>
                                    <a href="/bakiye" style="background:#222;color:#fff;padding:14px 22px;border-radius:10px;font-weight:700;text-decoration:none;display:inline-block;">
                                        Jeton Yükle
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <% }); %>
            </div>

            <!-- SAĞ PANEL -->
            <div class="col-lg-4 mt-30">
                <div style="display:flex;flex-direction:column;gap:20px;height:100%;">

                    <!-- SIRADAKİ İHALE -->
                    <div style="background:#fff;border-radius:18px;padding:22px;box-shadow:0 10px 30px rgba(0,0,0,0.12);">
                        <h2 class="section-heading mb-20"><span>Sıradaki İhale</span></h2>
                        <% slider.slice(1, 2).forEach(element => { %>
                        <div style="text-align:center;">
                            <img src="/slider/<%- element.slidegorsel %>" alt="" style="width:100%;height:180px;object-fit:contain;background:#fafafa;border-radius:12px;padding:10px;margin-bottom:12px;">
                            <h4 style="font-size:24px;font-weight:700;margin-bottom:10px;"><%- element.slideadi %></h4>
                            <p style="color:#666;margin-bottom:8px;"><%- element.slidealtadi %></p>
                            <p style="margin-bottom:8px;"><strong>Başlangıç:</strong> 14:30</p>
                            <p style="margin-bottom:14px;"><strong>Giriş Bedeli:</strong> <span style="color:#ff7a00;font-weight:700;">150 Jeton</span></p>
                            <a href="<%- element.slideurunlinki %>" style="background:#ff7a00;color:#fff;padding:12px 18px;border-radius:10px;text-decoration:none;font-weight:700;display:inline-block;">
                                Detayı Gör
                            </a>
                        </div>
                        <% }); %>
                    </div>

                    <!-- JETON PAKETLERİ -->
                    <div style="background:#fff;border-radius:18px;padding:22px;box-shadow:0 10px 30px rgba(0,0,0,0.12);">
                        <h2 class="section-heading mb-20"><span>Jeton Paketleri</span></h2>

                        <div style="display:flex;flex-direction:column;gap:12px;">
                            <div style="display:flex;justify-content:space-between;align-items:center;background:#f7f7f7;padding:14px 16px;border-radius:12px;">
                                <div>
                                    <strong>250 Jeton</strong>
                                    <div style="font-size:13px;color:#777;">Başlangıç paketi</div>
                                </div>
                                <div style="font-weight:700;color:#ff7a00;">149,90 TL</div>
                            </div>

                            <div style="display:flex;justify-content:space-between;align-items:center;background:#f7f7f7;padding:14px 16px;border-radius:12px;">
                                <div>
                                    <strong>500 Jeton</strong>
                                    <div style="font-size:13px;color:#777;">En çok tercih edilen</div>
                                </div>
                                <div style="font-weight:700;color:#ff7a00;">249,90 TL</div>
                            </div>

                            <div style="display:flex;justify-content:space-between;align-items:center;background:#f7f7f7;padding:14px 16px;border-radius:12px;">
                                <div>
                                    <strong>900 Jeton</strong>
                                    <div style="font-size:13px;color:#777;">Avantajlı paket</div>
                                </div>
                                <div style="font-weight:700;color:#ff7a00;">399,90 TL</div>
                            </div>
                        </div>

                        <a href="/bakiye" style="margin-top:16px;background:#222;color:#fff;padding:12px 18px;border-radius:10px;display:inline-block;text-decoration:none;font-weight:700;">
                            Hemen Jeton Yükle
                        </a>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>
<!-- hero end -->         
