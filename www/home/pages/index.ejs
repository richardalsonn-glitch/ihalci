<%- include('../partials/_headers'); %>

<!-- ====================== SADECE TAILWIND + MODERN TASARIM ====================== -->
<script src="https://cdn.tailwindcss.com"></script>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
<script src="https://unpkg.com/lucide@latest/dist/umd/lucide.js"></script>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');
  
  body {
    font-family: 'Inter', system_ui, sans-serif;
  }
  
  .product-card {
    transition: all 0.3s ease;
  }
  .product-card:hover {
    transform: translateY(-10px);
    box-shadow: 0 20px 25px -5px rgb(0 0 0 / 0.1), 0 8px 10px -6px rgb(0 0 0 / 0.1);
  }
  
  .hero-bg {
    background: linear-gradient(135deg, #f97316 0%, #c2410c 100%);
  }
</style>

<body class="bg-gray-50">

  <!-- NAVBAR -->
  <nav class="bg-white border-b sticky top-0 z-50">
    <div class="max-w-7xl mx-auto px-6 py-5 flex items-center justify-between">
      <div class="flex items-center gap-3">
        <span class="text-3xl font-bold text-orange-600">İhale<span class="text-gray-900">ci</span></span>
      </div>

      <div class="hidden md:flex items-center gap-8 text-sm font-medium">
        <a href="/" class="hover:text-orange-600 transition">Ana Sayfa</a>
        <a href="/kategoriler/kadin" class="hover:text-orange-600 transition">Kategoriler</a>
        <a href="/urun-ekle" class="hover:text-orange-600 transition">İhale Başlat</a>
      </div>

      <div class="flex items-center gap-4">
        <% if (cuzdan) { %>
          <div class="flex items-center gap-2 bg-amber-50 text-amber-700 px-5 py-2 rounded-3xl text-sm font-medium">
            <i data-lucide="coins" class="w-5 h-5"></i>
            <span><%= cuzdan.uyebakiye || 0 %> Jeton</span>
          </div>
        <% } %>

        <% if (user) { %>
          <a href="/hesabim" class="flex items-center gap-2 text-gray-700 hover:text-orange-600">
            <i data-lucide="user-circle" class="w-6 h-6"></i>
          </a>
        <% } else { %>
          <a href="/login" 
             class="bg-orange-600 hover:bg-orange-700 text-white px-6 py-3 rounded-2xl font-semibold transition">
            Giriş Yap
          </a>
        <% } %>
      </div>
    </div>
  </nav>

  <!-- HERO SECTION -->
  <div class="hero-bg text-white">
    <div class="max-w-7xl mx-auto px-6 py-20 grid md:grid-cols-12 gap-12 items-center">
      <div class="md:col-span-7 space-y-8">
        <div class="inline-flex items-center gap-2 bg-white/20 backdrop-blur-md px-6 py-3 rounded-full text-sm">
          🔥 Şu anda <span class="font-bold">142</span> aktif ihale var
        </div>

        <h1 class="text-5xl md:text-6xl font-bold leading-tight">
          En ucuza almak istiyorsan<br>
          <span class="text-amber-200">doğru yerdesin!</span>
        </h1>

        <p class="text-xl text-orange-100 max-w-lg">
          Jetonlu açık arttırma sistemiyle istediğin ürünü çok daha uygun fiyata kazan.
        </p>

        <a href="#aktif-ihaleler" 
           class="inline-flex items-center bg-white text-orange-600 font-semibold px-8 py-4 rounded-3xl hover:bg-amber-50 transition text-lg">
          Hemen İhalelere Göz At →
        </a>
      </div>

      <!-- Hero Sağ Taraf - Slider -->
      <% if (slider && slider.length > 0) { %>
        <div class="md:col-span-5">
          <% slider.slice(0,1).forEach(element => { %>
            <div class="bg-white rounded-3xl overflow-hidden shadow-2xl">
              <img src="/slider/<%= element.slidegorsel %>" 
                   class="w-full h-auto" alt="<%= element.slideadi %>">
              <div class="p-6">
                <div class="flex justify-between items-start">
                  <div>
                    <span class="text-orange-600 font-semibold">Sıcak İhale</span>
                    <h3 class="text-2xl font-bold text-gray-900 mt-1"><%= element.slideadi %></h3>
                  </div>
                  <div class="text-right">
                    <p class="text-3xl font-bold text-orange-600"><%= element.slideurunbaslangicfiyati %> TL</p>
                  </div>
                </div>
              </div>
            </div>
          <% }); %>
        </div>
      <% } %>
    </div>
  </div>

  <!-- AKTİF İHALELER -->
  <div id="aktif-ihaleler" class="max-w-7xl mx-auto px-6 py-16">
    <div class="flex items-center justify-between mb-10">
      <h2 class="text-4xl font-bold text-gray-900 flex items-center gap-3">
        <i data-lucide="flame" class="w-9 h-9 text-orange-500"></i>
        Aktif İhaleler
      </h2>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-8">
      <% urunler.forEach(element => { %>
        <div class="product-card bg-white rounded-3xl overflow-hidden border border-gray-100">
          <div class="relative h-64">
            <a href="/urunler/<%= element.ihaleurl %>">
              <img src="/urungorselleri/<%= element.urungorsel1 %>" 
                   class="w-full h-full object-cover" alt="<%= element.urunadi %>">
            </a>
            
            <!-- Geri Sayım -->
            <div class="absolute top-4 right-4 bg-black/75 text-white text-xs px-4 py-2 rounded-2xl flex items-center gap-2 font-mono">
              <i data-lucide="clock" class="w-4 h-4"></i>
              <span id="countdown-<%= element._id %>" class="countdown">02:45:19</span>
            </div>
          </div>

          <div class="p-6">
            <h3 class="font-semibold text-lg leading-tight line-clamp-2 h-14">
              <a href="/urunler/<%= element.ihaleurl %>" class="hover:text-orange-600">
                <%= element.urunadi %>
              </a>
            </h3>

            <div class="mt-6 flex justify-between items-end">
              <div>
                <p class="text-xs text-gray-500">Şu anki teklif</p>
                <p class="text-2xl font-bold text-orange-600">
                  <%= element.baslangicfiyati || element.urunfiyati %> TL
                </p>
              </div>
              <div class="text-right">
                <p class="text-xs text-gray-500">Başlangıç</p>
                <p class="line-through text-gray-400"><%= element.urunfiyati %> TL</p>
              </div>
            </div>

            <a href="/urunler/<%= element.ihaleurl %>" 
               class="mt-8 block w-full bg-orange-600 hover:bg-orange-700 text-white font-semibold py-4 rounded-2xl text-center transition">
              İhaleye Katıl
            </a>
          </div>
        </div>
      <% }); %>
    </div>
  </div>

</body>

<!-- Lucide Icons Aktifleştir -->
<script>
  lucide.createIcons();

  // Basit geri sayım (ileride gerçek zamanlı yapacağız)
  document.querySelectorAll('.countdown').forEach(el => {
    let timeLeft = 7200; // 2 saat örnek

    const timer = setInterval(() => {
      timeLeft--;
      if (timeLeft <= 0) {
        el.textContent = "SÜRE DOLDU";
        clearInterval(timer);
        return;
      }

      const hours = Math.floor(timeLeft / 3600);
      const minutes = Math.floor((timeLeft % 3600) / 60);
      const seconds = timeLeft % 60;

      el.textContent = `${hours.toString().padStart(2, '0')}:${minutes.toString().padStart(2, '0')}:${seconds.toString().padStart(2, '0')}`;
    }, 1000);
  });
</script>

<%- include('../partials/_footers'); %>
